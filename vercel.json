{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": ["dist/server.cjs", "indexed_db.json"]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
